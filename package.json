{
  "name": "elektron-seeder-startos",
  "version": "0.1.2",
  "description": "StartOS service wrapper for the Elektron Net DNS seeder",
  "private": true,
  "scripts": {
    "build": "rm -rf ./javascript && ncc build startos/index.ts -o ./javascript",
    "check": "tsc --noEmit",
    "install:s9pk": "start-cli package install",
    "clean": "rm -rf node_modules javascript *.s9pk"
  },
  "dependencies": {
    "@start9labs/start-sdk": "^1.5.3",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.4.0"
  }
}
